<odoo>
    <data>

        <record model="ir.actions.act_window" id="action_hr_executing_provisions">
            <field name="name">Ejecutar Provisiones</field>
            <field name="res_model">hr.executing.provisions</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Crear record rule para filtrar las compañias-->
        <record id="rule_hr_payroll_provisions_company" model="ir.rule">
            <field name="name">Permisos compañia Provisiones</field>
            <field name="model_id" ref="model_hr_executing_provisions"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record model="ir.ui.view" id="hr_executing_provisions_list">
            <field name="name">hr executing provisions list</field>
            <field name="model">hr.executing.provisions</field>
            <field name="arch" type="xml">
                <list>
                    <field name="year"/>
                    <field name="month"/>
                    <field name="company_id"/>
                    <field name="observations"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="hr_executing_provisions_form">
            <field name="name">hr executing provisions form</field>
            <field name="model">hr.executing.provisions</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="executing_provisions" type="object" string="Provisionar" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="get_accounting" type="object" string="Contabilizar" class="oe_highlight" invisible="state != 'done'"/>
                        <button name="cancel_process" type="object" string="Cancelar" invisible="state not in ['draft', 'done']"/>
                        <button name="restart_accounting" type="object" string="Reiniciar Contabilización" invisible="state != 'accounting'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Periodo">
                                <field name="year"/>
                                <field name="month"/>
                            </group>
                            <group string="Observaciones">
                                <field name="observations" nolabel="1" colspan="2"/>
                            </group>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="employees_per_batch"/>
                            <field name="time_process" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Ejecución">
                                <field name="details_ids" readonly="1" force_save="1" colspan="2">
                                    <list>
                                        <field name="provision"/>
                                        <field name="employee_id"/>
                                        <field name="version_id" optional="show"/>
                                        <field name="value_wage" optional="show"/>
                                        <field name="value_base" optional="show"/>
                                        <field name="time" optional="show"/>
                                        <field name="amount" optional="show"/>
                                        <field name="value_payments" optional="show"/>
                                        <field name="current_payable_value" optional="show"/>
                                        <field name="value_balance" optional="show"/>
                                    </list>
                                    <form>
                                        <header>
                                            <button class="oe_highlight" name="executing_provisions_employee" string="Recalcular" type="object"/>
                                        </header>
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="executing_provisions_id"/>
                                                    <field name="employee_id"/>
                                                    <field name="analytic_distribution" widget="analytic_distribution"/>
                                                    <field name="value_base"/>
                                                    <field name="value_balance"/>
                                                    <field name="amount"/>
                                                </group>
                                                <group>
                                                    <field name="provision"/>
                                                    <field name="version_id"/>
                                                    <field name="value_wage"/>
                                                    <field name="time"/>
                                                    <field name="value_payments"/>
                                                    <field name="current_payable_value"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Advertencias" name="advertencias">
                                <group>
                                    <field name="errors_provisions_ids" colspan="2" readonly="1" nolabel="1">
                                        <list>
                                            <field name="employee_id"/>
                                            <field name="version_id" optional="show"/>
                                            <field name="description" optional="show"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                        <group>
                            <field name="move_id" readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
    </data>
</odoo>