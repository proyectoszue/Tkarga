<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_partner_bank_form_zue_account" model="ir.ui.view">
            <field name="name">res.partner.bank.form.zue.account.inherit</field>
            <field name="model">res.partner.bank</field>
            <field name="priority">10</field>
            <field name="inherit_id" ref="base.view_partner_bank_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='acc_number']" position="after">
                    <field name="type_account"/>
                </xpath>
                <xpath expr="//field[@name='bank_id']" position="after">
                    <field name="z_partner_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_company_zue_account_form" model="ir.ui.view">
            <field name="name">res.company.zue.account.form.inherit</field>
            <field name="model">res.company</field>
            <field name="priority">50</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='social_media']" position="after">
                    <group string="Notas Facturación Electrónica">
                        <field name="note_id" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="note"/>
                                <field name="company_id" column_invisible="1"/>
                            </list>
                        </field>
                    </group>
                    <group string="Conciliacion bancaria">
                        <field name="z_bank_auto_reconcile_receivable_payable_only"/>
                        <field name="z_bank_auto_reconcile_exact_match_only"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_partner_zue_account_orp_form" model="ir.ui.view">
            <field name="name">res.partner.zue.account.orp.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="priority">80</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                    <page string="Operaciones Recíprocas">
                        <group>
                            <field name="z_partner_with_reciprocal_operations"/>
                            <field name="z_code_partner_reciprocal_operations"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
