<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.actions.act_window" id="action_bank_movement_types">
            <field name="name">Tabla de tipos de movimiento</field>
            <field name="res_model">zue.bank.movement.types</field>
            <field name="view_mode">list</field>
        </record>

        <record id="bank_movement_types_tree" model="ir.ui.view">
            <field name="name">Tabla de tipos de movimiento</field>
            <field name="model">zue.bank.movement.types</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="z_movement_types"/>
                    <field name="z_movement_name"/>
                    <field name="z_bank_id"/>
                </list>
            </field>
        </record>
    </data>
</odoo>