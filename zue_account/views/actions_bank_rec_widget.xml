<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bank_statement_line_kanban_bank_rec_widget_zue" model="ir.ui.view">
            <field name="name">account.bank.statement.line.kanban.bank_rec_widget.zue</field>
            <field name="model">account.bank.statement.line</field>
            <field name="inherit_id" ref="account_accountant.view_bank_statement_line_kanban_bank_rec_widget"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="z_bank_auto_reconcile_receivable_payable_only"/>
                </xpath>
            </field>
        </record>

        <record id="view_bank_statement_line_tree_bank_rec_widget_zue" model="ir.ui.view">
            <field name="name">account.bank.statement.line.list.bank_rec_widget.zue</field>
            <field name="model">account.bank.statement.line</field>
            <field name="inherit_id" ref="account_accountant.view_bank_statement_line_tree_bank_rec_widget"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="z_bank_auto_reconcile_receivable_payable_only" column_invisible="True"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
