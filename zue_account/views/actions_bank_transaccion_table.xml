<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.actions.act_window" id="action_bank_transaction_table">
            <field name="name">Tabla de transacciones</field>
            <field name="res_model">zue.bank.transaction.table</field>
            <field name="view_mode">list</field>
        </record>

        <record id="bank_transaction_table_tree" model="ir.ui.view">
            <field name="name">Tabla de transacciones</field>
            <field name="model">zue.bank.transaction.table</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="z_transaction_code"/>
                    <field name="z_account_nature"/>
                    <field name="z_transaction_name"/>
                    <field name="z_bank_id"/>
                </list>
            </field>
        </record>
    </data>
</odoo>