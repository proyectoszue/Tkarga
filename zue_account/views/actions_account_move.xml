<odoo>
    <data>
		<record id="view_zue_account_form_account_move" model="ir.ui.view">
			<field name="name">zue_account.account_move_inherit</field>
			<field name="model">account.move</field>
			<field name="priority">20</field>
			<field name="inherit_id" ref="account.view_move_form"/>
			<field name="arch" type="xml">
                <!-- Ajustes Facturas Proveedor - Campos Obligatorios -->
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="supplier_invoice_attachment"  invisible="move_type != 'in_invoice'"/>
                    <field name="supplier_invoice_number"  invisible="move_type != 'in_invoice'"/>
                </xpath>
                <!-- Ajustes Detalle - Campos Obligatorios -->
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='invoice_line_ids']/list[1]/field[@name='analytic_distribution']" position="attributes">
                    <attribute name="required">True</attribute>
                </xpath>
<!--                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[2]/field[@name='line_ids']/list[1]/field[@name='partner_id']" position="attributes">-->
<!--                    <attribute name="required">required_partner</attribute>-->
<!--                </xpath>-->
<!--                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[2]/field[@name='line_ids']/list[1]/field[@name='tax_base_amount']" position="attributes">-->
<!--                    <attribute name="readonly">False</attribute>                    -->
<!--                    <attribute name="invisible">False</attribute>                    -->
<!--                    <attribute name="force_save">True</attribute> -->
<!--                </xpath>-->

                <xpath expr="//field[@name='tax_totals']" position="after">
                    <field name="iva_amount"/>
                    <field name="tax_base_amount" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='invoice_vendor_bill_id']" position="after">
                    <field name="is_invoice_ref" invisible="move_type != 'out_refund'"/>
                    <field name="move_ref_id" invisible="state != 'posted' or move_type != 'out_refund'"/> <!--invisible="move_type != 'out_refund' or state != 'posted'"-->
                </xpath>
			</field>
		</record>

        <!-- Crear record rule para filtrar las compañias-->
        <record id="rule_annual_accounting_closing_security_company" model="ir.rule">
            <field name="name">Permisos compañia cierre contable anual</field>
            <field name="model_id" ref="model_annual_accounting_closing"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record model="ir.actions.act_window" id="action_annual_accounting_closing">
            <field name="name">Cierre contable</field>
            <field name="res_model">annual.accounting.closing</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.ui.view" id="annual_accounting_closing_list">
            <field name="name">annual accounting closing list</field>
            <field name="model">annual.accounting.closing</field>
            <field name="arch" type="xml">
                <list>
                    <field name="closing_year"/>
                    <field name="balance"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="annual_accounting_closing_form">
            <field name="name">annual accounting closing form</field>
            <field name="model">annual.accounting.closing</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="call_up_closing_wizard" type="object" string="Generar cierre" confirm="El movimiento contable actual para el cierre será borrado para crear uno nuevo. Desea continuar?"/>
                    </header>
                    <sheet>
                        <div class="oe_right oe_button_box" name="buttons">
                            <button name="return_action_to_open"
                                class="oe_inline oe_stat_button" style="width: 200px !important;"
                                icon="fa-list" invisible="counter_contab == 0"
                                type="object">
                                <field name="counter_contab" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <field name="name"/>
                            <field name="closing_year"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Datos de Cierre">
                            <field name="journal_id" required="1"/>
                            <field name="counterparty_account" invisible="closing_by_partner"/>
                            <field name="closing_by_partner"/>
                            <field name="filter_account_ids" widget="many2many_tags" invisible="not closing_by_partner"/>
                            <field name="partner_id" invisible="not closing_by_partner"/>
                        </group>
                        <group string="Saldo de cierre">
                            <h3><field name="balance" nolabel="1" readonly="1" force_save="1"/></h3>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
