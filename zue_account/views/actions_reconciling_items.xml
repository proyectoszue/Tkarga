<odoo>
    <data>
        <record model="ir.actions.act_window" id="action_zue_reconciling_items_encab">
            <field name="name">Conciliación partidas conciliatorias</field>
            <field name="res_model">zue.reconciling.items.encab</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.ui.view" id="zue_reconciling_items_encab_list">
            <field name="name">zue reconciling items encab list</field>
            <field name="model">zue.reconciling.items.encab</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="z_year"/>
                    <field name="z_month"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="zue_reconciling_items_encab_form">
            <field name="name">zue reconciling items encab form</field>
            <field name="model">zue.reconciling.items.encab</field>
            <field name="arch" type="xml">
                <form>
                  <header>
                      <button name="process" type="object" string="Procesar" invisible="state != 'draft'" class="oe_highlight"/>
                      <field name="state" widget="statusbar"/>
                  </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="return_action_to_open"
                            class="oe_stat_button"
                            icon="fa-list" invisible="z_counter_extract == 0"
                            type="object">
                            <field name="z_counter_extract" string="Extractos" widget="statinfo"/>
                        </button>
                        <button name="return_action_to_open_opening_moves"
                            class="oe_stat_button"
                            icon="fa-arrow-circle-up"
                            invisible="z_counter_opening_move == 0"
                            type="object">
                            <field name="z_counter_opening_move" string="Apertura" widget="statinfo"/>
                        </button>
                        <button name="return_action_to_open_closing_moves"
                            class="oe_stat_button"
                            icon="fa-arrow-circle-down"
                            invisible="z_counter_closing_move == 0"
                            type="object">
                            <field name="z_counter_closing_move" string="Cierre" widget="statinfo"/>
                        </button>
                        <button name="return_action_to_open_opening_moves"
                            class="oe_inline oe_stat_button" style="width: 200px !important;"
                            icon="fa-arrow-circle-up" invisible="z_counter_opening_move == 0"
                            type="object">
                            <field name="z_counter_opening_move" widget="statinfo"/>
                        </button>
                        <button name="return_action_to_open_closing_moves"
                            class="oe_inline oe_stat_button" style="width: 200px !important;"
                            icon="fa-arrow-circle-down" invisible="z_counter_closing_move == 0"
                            type="object">
                            <field name="z_counter_closing_move" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="z_year"/>
                            <field name="z_month"/>
                            <field name="z_search_all"/>
                            <button name="search_reconciling_items" type="object" string="Buscar" icon="fa-search"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Partidas conciliatorias pendientes" name="ejecution">
                            <field name="z_reconciling_detail" nolabel="1">
                                <list>
                                    <field name="z_date" readonly="1" optional="show"/>
                                    <field name="z_payment_ref" readonly="1" optional="show"/>
                                    <field name="z_partner_id" readonly="1" optional="show"/>
                                    <field name="z_amount" readonly="1" optional="show"/>
                                    <field name="z_statement_id" readonly="1" optional="show"/>
                                    <field name="z_journal_id" readonly="1" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Extractos generados" name="created_statements" invisible="z_counter_extract == 0">
                            <field name="z_statement_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="date" optional="show"/>
                                    <field name="name" optional="show"/>
                                    <field name="journal_id" optional="show"/>
                                    <field name="balance_end_real" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Registros generados" name="created_lines" invisible="z_counter_record == 0">
                            <field name="z_statement_line_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="date" optional="show"/>
                                    <field name="payment_ref" optional="show"/>
                                    <field name="partner_id" optional="show"/>
                                    <field name="amount" optional="show"/>
                                    <field name="statement_id" optional="show"/>
                                    <field name="is_reconciled" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Asientos creados" name="created_moves" invisible="z_counter_move == 0">
                            <field name="z_move_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="date" optional="show"/>
                                    <field name="name" optional="show"/>
                                    <field name="ref" optional="show"/>
                                    <field name="partner_id" optional="show"/>
                                    <field name="journal_id" optional="show"/>
                                    <field name="move_type" optional="show"/>
                                    <field name="state" optional="show"/>
                                    <field name="auto_post" optional="show"/>
                                    <field name="statement_line_id" optional="show"/>
                                    <field name="reversed_entry_id" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
