<odoo>
    <data>
		<record id="view_zue_account_form_account_account" model="ir.ui.view">
			<field name="name">zue_account.account_account_inherit</field>
			<field name="model">account.account</field>
			<field name="priority">20</field>
			<field name="inherit_id" ref="account.view_account_form"/>
			<field name="arch" type="xml">                
				<xpath expr="//field[@name='currency_id']" position="after">					
					<field name="accounting_class"/>	
<!--                    <field name="required_partner" />-->
					<field name="exclude_balance_test"/>
					<field name="z_not_disaggregate_partner_balance_test"/>
					<field name="z_account_value"/>
					<field name="z_code_cgn"/>
                </xpath>
			</field>
		</record>

		<record id="view_zue_account_form_account_tax" model="ir.ui.view">
			<field name="name">zue_account.account_tax_inherit</field>
			<field name="model">account.tax</field>
			<field name="priority">20</field>
			<field name="inherit_id" ref="account.view_tax_form"/>
			<field name="arch" type="xml">
                <xpath expr="//field[@name='country_id']" position="after">
					<field name="has_minimum_base"/>
					<field name="minimum_base" invisible="has_minimum_base == False"/>
                </xpath>
				<xpath expr="//field[@name='is_base_affected']" position="after">
					<field name="is_base_affected_only_taxes"/>
					<field name="base_affected_only_taxes_id"/>
                </xpath>
			</field>
		</record>

		<record id="view_zue_account_form_account_account_code" model="ir.ui.view">
			<field name="name">zue_account.account_account_inherit</field>
			<field name="model">account.group</field>
			<field name="priority">20</field>
			<field name="inherit_id" ref="account.view_account_group_form"/>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='company_id']" position="after">
					<field name="z_code_cgn"/>
                </xpath>
			</field>
		</record>

		<record id="view_zue_account_latam_identification_type" model="ir.ui.view">
			<field name="name">zue_account.l10n_latam_identification_type</field>
			<field name="model">l10n_latam.identification.type</field>
			<field name="priority">20</field>
			<field name="inherit_id" ref="l10n_latam_base.view_l10n_latam_identification_type_tree"/>
			<field name="arch" type="xml">
				<xpath expr="//list" position="attributes">
					<attribute name="editable">bottom</attribute>
					<attribute name="create">1</attribute>
    				<attribute name="edit">1</attribute>
				</xpath>
				<xpath expr="//field[@name='name']" position="after">
					<field name="z_code_dian"/>
				</xpath>
			</field>
		</record>
    </data>
</odoo>
