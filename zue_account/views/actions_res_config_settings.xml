<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="zue_account_res_config_settings_form_inherit" model="ir.ui.view">
            <field name="name">zue_account.res_config_settings.form.inherit</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="priority" eval="16"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='fiscal_localization_setting_container']" position="after">
                    <block title="Informes CO" id="reports_co_zue">
                        <setting id="zue_reports_co_settings_code_cgn">
                            <label for="z_entity_code_cgn"/>
                            <div>
                                <field name="z_entity_code_cgn"/>
                            </div>
                        </setting>
                        <setting id="zue_reports_co_settings_certificates_id">
                            <label for="z_folder_retention_certificates_id"/>
                            <div>
                                <field name="z_folder_retention_certificates_id"/>
                            </div>
                        </setting>
                        <setting id="zue_reports_co_settings_moves_balance">
                            <label for="z_qty_thread_moves_balance"/>
                            <div>
                                <field name="z_qty_thread_moves_balance"/>
                            </div>
                        </setting>
                        <setting id="zue_reports_co_settings_thread_balance">
                            <label for="z_qty_thread_balance"/>
                            <div>
                                <field name="z_qty_thread_balance"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Multicash" id="multicash_zue">
                        <setting id="zue_multicash_to_validate_setting">
                            <label for="z_folder_multicash_to_validate_id"/>
                            <div>
                                <field name="z_folder_multicash_to_validate_id"/>
                            </div>
                        </setting>
                        <setting id="zue_multicash_validate_setting">
                            <label for="z_folder_multicash_validate_id"/>
                            <div>
                                <field name="z_folder_multicash_validate_id"/>
                            </div>
                        </setting>
                        <setting id="zue_multicash_issue_setting">
                            <label for="z_folder_multicash_issue_id"/>
                            <div>
                                <field name="z_folder_multicash_issue_id"/>
                            </div>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
