<odoo>
    <data>

        <record id="res_country_form_zue_erp_inherit" model="ir.ui.view">
            <field name="name">res.country.form.zue.erp.inherit</field>
            <field name="model">res.country</field>
            <field name="priority">10</field>
            <field name="inherit_id" ref="base.view_country_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='code']" position="after">
                    <field name="z_code_dian"/>
                    <field name="z_skip_validation"/>
                  </xpath>
            </field>
        </record>

        <record id="res_country_state_tree_zue_erp_inherit" model="ir.ui.view">
            <field name="name">res.country.state.tree.zue.erp.inherit</field>
            <field name="model">res.country.state</field>
            <field name="priority">10</field>
            <field name="inherit_id" ref="base.view_country_state_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list[1]/field[@name='name']" position="after">
                    <field name="z_code_dian" optional="show"/>
                  </xpath>
            </field>
        </record>

        <record id="res_city_tree_zue_erp_inherit" model="ir.ui.view">
            <field name="name">res.city.tree.zue.erp.inherit</field>
            <field name="model">res.city</field>
            <field name="priority">10</field>
            <field name="inherit_id" ref="base_address_extended.view_city_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list[1]/field[@name='name']" position="after">
                    <field name="z_code_dian" optional="show"/>
                  </xpath>
            </field>
        </record>

        <record id="view_partner_zue_erp_form" model="ir.ui.view">
            <field name="name">res.partner.zue.erp.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="priority">10</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/span[1]" position="before">
                    <field name="is_company" invisible="1"/>
                    <field name="x_type_thirdparty" widget="many2many_checkboxes" required="0"/>
                    <xpath expr="//field[@name='vat']" position="move"/>
                    <field name="x_digit_verification"/>
                    <field name="x_business_name" invisible="not is_company"/>
                    <field name="x_first_name" invisible="is_company"/>
                    <field name="x_second_name" invisible="is_company"/>
                    <field name="x_first_lastname" invisible="is_company"/>
                    <field name="x_second_lastname" invisible="is_company"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/div[1]/field[@name='zip']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='child_ids']/form[1]/sheet[1]/group[1]/group[1]/div[1]/field[@name='zip']"
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='child_ids']/form[1]/sheet[1]/group[1]/group[1]/div[1]/field[@name='city']"
                       position="replace">
                    <field name="city" invisible="1"/>
                    <field name="city_id" placeholder="Ciudad" class="o_address_city"
                           domain="[('country_id', '=', country_id), ('state_id', '=', state_id)]"
                           context="{'default_country_id': country_id, 'default_state_id': state_id}"/>
                </xpath>
                <xpath expr="//field[@name='website']" position="after">
                    <field name="x_ciiu_activity" domain="[['child_ids','=',False]]"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]" position="inside">
                    <span class="o_form_label o_td_label">
                        <b>Info. Expedición documento</b>
                    </span>
                    <div class="o_address_format">
                        <field name="x_vat_expedition_date" placeholder="Fecha" class="font-weight-bold"/>
                        <field name="z_country_issuance_id" placeholder="Pais" class="o_address_country"/>
                        <field name="z_department_issuance_id" placeholder="Departamento"
                               class="o_address_state" domain="[['country_id','=',z_country_issuance_id]]"/>
                        <field name="z_city_issuance_id_new" placeholder="Ciudad" class="o_address_city"
                               domain="[['state_id','=',z_department_issuance_id]]"/>
                    </div>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="company_id" string="Compañía" required="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
