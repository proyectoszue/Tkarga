    <data>
        <record id="view_partner_bank_tree_zue_hr_payroll" model="ir.ui.view">
            <field name="name">res.partner.bank.tree.zue.hr.payroll.inherit</field>
            <field name="model">res.partner.bank</field>
            <field name="priority">10</field>
            <field name="inherit_id" ref="base.view_partner_bank_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='acc_number']" position="after">
                    <field name="is_main" string="Es Principal"/>
                </xpath>
            </field>
        </record>

        <record id="view_partner_bank_form_zue_hr_payroll" model="ir.ui.view">
