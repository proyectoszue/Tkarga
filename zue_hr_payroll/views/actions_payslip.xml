        <record id="hr_payslip_run_view_kanban_buttons_payslip" model="ir.ui.view">
            <field name="name">hr.payroll.zue.hr.payslip.lote.kanban.buttons.inherit</field>
            <field name="model">hr.payslip.run</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_payroll.hr_payslip_run_view_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_validate']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='action_paid']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='unlink']" position="after">
                    <button name="assign_status_validated" type="object" string="Verificar" invisible="state != '01_ready'"/>
                    <button name="restart_payroll_batch" type="object" string="Reiniciar" invisible="state not in ['02_close', '01_ready']"/>
                    <button name="restart_payroll_account_batch" type="object" string="Reversar contabilización" invisible="state not in ['03_paid', '04_cancel']"/>
                    <button name="restart_full_payroll_batch" type="object" string="Reversar totalmente" invisible="state not in ['03_paid', '04_cancel']"/>
                    <button name="generate_settlement_report_entity" type="object" string="Reporte por entidad" invisible="state not in ['03_paid', '04_cancel']"/>
                    <button name="action_open_form" type="object" string="Editar"/>
                </xpath>
            </field>
        </record>

        <record id="view_hr_payslip_tree_zue" model="ir.ui.view">
            <field name="name">hr.payslip.list.zue</field>
            <field name="model">hr.payslip</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_payslip_paid']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='action_move_to_off_cycle']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='issues']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='state_display']" position="replace">
                    <field name="state"/>
                </xpath>
            </field>
        </record>


        <!-- Formulario de nomina lotes botones -->
        <record id="view_zue_hr_payroll_lote_buttons_payslip" model="ir.ui.view">
            <field name="name">hr.payroll.zue.hr.payslip.lote.buttons.inherit</field>
            <field name="model">hr.payslip.run</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/group[1]" position="before">
                    <header>
                        <button name="assign_status_validated" type="object" string="Verificar" invisible="state != '01_ready'"/>
                        <button name="restart_payroll_batch" type="object" string="Reiniciar" invisible="state not in ['02_close', '01_ready']"/>
                        <button name="restart_payroll_account_batch" type="object" string="Reversar contabilización" invisible="state not in ['03_paid', '04_cancel']"/>
                        <button name="restart_full_payroll_batch" type="object" string="Reversar totalmente" invisible="state not in ['03_paid', '04_cancel']"/>
                        <button name="generate_settlement_report_entity" type="object" string="Reporte por entidad" invisible="state not in ['03_paid', '04_cancel']"/>
                    </header>
                </xpath>
                <xpath expr="//form[1]/group[1]" position="after">
                    <group>
                        <field name="observations" force_save="1" readonly="1" invisible="not observations"/>
                        <field name="time_process" force_save="1" readonly="1" invisible="not time_process"/>
                    </group>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="before">
                    <field name="name" readonly="0" required="1"/>
                    <field name="definitive_plan" readonly="0"/>
                </xpath>
                <xpath expr="//field[@name='schedule_pay']" position="replace">
                    <field name="structure_process" invisible="1"/>
                    <field name="z_filter_state_finished" widget="radio"/>
                    <field name="method_schedule_pay" widget="radio"/>
                    <field name="prima_run_reverse_id" invisible="structure_process != 'prima'"
                           options="{'no_create': True, 'no_quick_create': True}"/>
                </xpath>
                <xpath expr="//field[@name='structure_id']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>
            </field>
        </record>
        <!-- Formulario tipos de entradas de trabajo -->
        <record id="view_zue_hr_payroll_work_entry_type" model="ir.ui.view">
            <field name="name">hr.payroll.zue.work.entry.type.inherit</field>
            <field name="model">hr.work.entry.type</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_work_entry.hr_work_entry_type_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='time_off']" position="after">
                    <group>
                        <field name="short_name"/>
                        <field name="deduct_deductions" widget="radio"/>
                        <field name="not_contribution_base"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
