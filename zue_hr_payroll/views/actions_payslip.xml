<odoo>
    <data>

        <!-- Crear record rule para filtrar las sucursales - Ausencias -->
        <record id="rule_leave_zue_res_branch" model="ir.rule">
            <field name="name">Permisos sucursales ausencias</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="domain_force">['|',('branch_id','in',user.branch_ids.ids),('branch_id','=',False)]</field>
        </record>

        <record id="rule_payslip_zue_res_branch" model="ir.rule">
            <field name="name">Permisos sucursales nóminas</field>
            <field name="model_id" ref="model_hr_payslip"/>
            <field name="domain_force">['|',('employee_id.branch_id','in',user.branch_ids.ids),('employee_id.branch_id','=',False)]</field>
        </record>

        <!-- Formulario de nomina -->
        <record id="view_zue_hr_payroll_form_payslip" model="ir.ui.view">
            <field name="name">hr.payroll.zue.hr.payslip.form.inherit</field>
            <field name="model">hr.payslip</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/header[1]/button[2]" position="before">
                    <button name="restart_payroll" type="object" string="Reiniciar" invisible="state != 'validated'"/>
                </xpath>
                <xpath expr="//form[1]/header[1]/button[@name='action_payslip_paid']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath><xpath expr="//form/header/button[@name='action_payslip_payment_report']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='employee_id']" position="attributes">
                    <attribute name="domain">[['company_id','=',company_id]]</attribute>
                </xpath>
                <xpath expr="//form[1]/header[1]/field[@name='state']" position="attributes">
                    <attribute name="statusbar_visible">draft,validated</attribute>
                </xpath>
                <xpath expr="//field[@name='journal_id']" position="before">
                    <field name="analytic_distribution" widget="analytic_distribution" readonly="1" force_save="1"/>
                </xpath>
                <xpath expr="//field[@name='struct_id']" position="after">
                    <field name="struct_process" invisible="1"/>
                    <field name="z_version_domain_ids" invisible="1"/>
                    <field name="refund_date" invisible="struct_process != 'vacaciones'"/>
                    <field name="z_vacation_contract_line_skip" invisible="1"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[3]/field[@name='line_ids']" position="before">
                    <div class="alert alert-danger mb-3" role="alert"
                         invisible="struct_process != 'contrato' or not z_vacation_contract_line_skip">
                        La línea de vacaciones no se ha agregado porque el histórico indica que ya fueron liquidadas previamente.
                    </div>
                </xpath>
                <xpath expr="//field[@name='version_id']" position="attributes">
                    <attribute name="domain">[('id', 'in', z_version_domain_ids)]</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
                    <group string="Liq. de Contrato" invisible="struct_process != 'contrato'" style="border-style:solid; padding:10px">
                        <group>
                            <field name="date_liquidacion" invisible="struct_process != 'contrato'" required="struct_process == 'contrato'" readonly="state == 'validated'"/>
                            <field name="reason_retiro" invisible="struct_process != 'contrato'" readonly="state == 'validated'"/>
                            <field name="have_compensation" invisible="struct_process != 'contrato'" readonly="state == 'validated'"/>
                            <field name="settle_payroll_concepts" invisible="struct_process != 'contrato'" readonly="state == 'validated'"/>
                            <field name="novelties_payroll_concepts" invisible="struct_process != 'contrato'" readonly="state == 'validated'"/>
                            <field name="z_no_days_worked" invisible="struct_process != 'contrato'" readonly="state == 'validated'"/>
                        </group>
                        <group>
                            <field name="date_prima" invisible="struct_process != 'contrato'" required="struct_process == 'contrato'" readonly="state == 'validated'" force_save="1"/>
                            <field name="date_cesantias" invisible="struct_process != 'contrato'" required="struct_process == 'contrato'" readonly="state == 'validated'" force_save="1"/>
                            <field name="date_vacaciones" invisible="struct_process != 'contrato'" required="struct_process == 'contrato'" readonly="state == 'validated'" force_save="1"/>
                        </group>
                    </group>
                    <group invisible="struct_process not in ['cesantias', 'intereses_cesantias', 'contrato']">
                        <field name="z_is_advance_severance" invisible="struct_process not in ['cesantias', 'intereses_cesantias']"/>
                        <field name="z_value_advance_severance" invisible="not z_is_advance_severance" required="z_is_advance_severance"/>
                        <field name="employee_severance_pay" invisible="struct_process not in ['cesantias', 'intereses_cesantias', 'contrato']"/>
                        <field name="severance_payments_reverse" invisible="struct_process not in ['cesantias', 'intereses_cesantias', 'contrato']" widget="many2many_tags"/>
                    </group>
                    <group invisible="struct_process not in ['prima']">
                        <field name="prima_payslip_reverse_id" invisible="struct_process not in ['prima']"/>
                    </group>
                    <group invisible="struct_process != 'vacaciones'" style="border-style:solid; padding:10px">
                        <group colspan="4">
                            <field name="paid_vacation_ids" invisible="struct_process != 'vacaciones'" readonly="state == 'validated'">
                                <list editable="bottom">
                                    <field name="paid_vacation_days"/>
                                    <field name="start_date_paid_vacation"/>
                                    <field name="end_date_paid_vacation" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </group>
                    </group>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[3]/field[@name='line_ids']/list[1]/field[@name='code']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[3]/field[@name='line_ids']/list[1]/field[@name='rate']" position="replace">
                    <field name="initial_accrual_date" optional="show"/>
                    <field name="final_accrual_date" optional="show"/>
                    <field name="amount_base" optional="show"/>
                    <field name="entity_id" optional="show"/>
                    <field name="loan_id" optional="show"/>
                </xpath>
                <xpath expr="//page[field[@name='input_line_ids']]" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[3]/field[@name='line_ids']" position="after">
                    <group class="oe_subtotal_footer oe_right" colspan="2" invisible="not rtefte_id">
                        <field name="rtefte_id"/>
                    </group>
                    <group class="oe_subtotal_footer oe_right" colspan="2" invisible="struct_process == 'nomina'">
                        <button string="Excel acumulados valores variables" name="base_values_export_excel" type="object"/>
                    </group>
                    <group class="d-flex justify-content-end" colspan="12">
                        <button string="Excel Líneas de recibo de nómina" name="get_excel_lines" type="object"/>
                    </group>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='worked_days_line_ids']/list[1]/field[@name='amount']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[3]" position="after">
                    <page string="Reglas no aplicadas">
                        <field name="not_line_ids" colspan="4" nolabel="1" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="code" column_invisible="1"/>
                                <field name="category_id"/>
                                <field name="sequence" column_invisible="1"/>
                                <field name="quantity"/>
                                <field name="entity_id"/>
                                <field name="loan_id"/>
                                <field name="salary_rule_id"/>
                                <field name="amount"/>
                                <field name="total"/>
                            </list>
                        </field>
                    </page>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[3]" position="after">
                    <page string="Observaciones">
                        <group col="4" string="Observaciones">
                            <field name="observation" colspan="4" nolabel="1"/>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//field[@name='payslip_run_id']" position="after">
                    <field name="definitive_plan" readonly="1"/>
                </xpath>
            </field>
        </record>
