<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="reports_payslip_header_footer_template">
            <t t-call="web.html_container">
                <t t-foreach="inside_foreach_docs or docs" t-as="o">
                    <t t-set="cp_template" t-value="o.get_hr_payslip_reports_template()"/>
                    <t t-if="cp_template.type_header_footer == 'default'">
                        <t t-call="web.external_layout">
                            <!-- Contenido dependiendo la estructura -->
                            <t t-if="cp_template.type_report == 'nomina'">
                                <t t-call="hr_payroll.report_payslip"/>
                            </t>
                            <t t-if="cp_template.type_report == 'vacaciones'">
                                <t t-call="zue_hr_payroll.report_liquidacion_vacaciones_document"/>
                            </t>
                            <t t-if="cp_template.type_report in ('prima','cesantias','intereses_cesantias')">
                                <t t-call="zue_hr_payroll.report_liquidacion_cesantias_prima_document"/>
                            </t>
                            <t t-if="cp_template.type_report == 'contrato'">
                                <t t-call="zue_hr_payroll.report_liquidacion_final_document"/>
                            </t>
                            <!-- Firmas y observaciones -->
                            <div style="font-style: normal; font-size: 12px;">
                                <div class="col-md-6 col-md-offset-9">
                                    <t t-if="cp_template.show_observation == True">
                                        <b>Observaciones:</b>
                                        <br/>
                                        <t t-if="o.observation">
                                            <span t-field="o.observation"/>
                                        </t>
                                    </t>
                                    <t t-if="cp_template.notes">
                                        <br/>
                                        <span t-esc="cp_template.notes"/>
                                    </t>
                                    <t t-if="cp_template.signature_prepared == True or cp_template.signature_reviewed == True or cp_template.signature_approved == True or cp_template.signature_employee == True">
                                        <br/>
                                        <br/>
                                        <br/>
                                        <br/>
                                        <table class="table table-striped">
                                            <tr class="text-center">
                                                <!-- Estado Hecho o Elaboró -->
                                                <td style="width: 25%" t-if="cp_template.z_signature_done or cp_template.signature_prepared">
                                                    <strong>ELABORÓ</strong>
                                                    <!-- signature_prepared = True -->
                                                    <t t-if="cp_template.signature_prepared">
                                                        <br/>
                                                        <t t-if="cp_template.z_txt_signature_prepared_contact == '$_name_employee'">
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="o.employee_id.name"/>
                                                            <br/>
                                                            <span>C.C: </span>
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="o.employee_id.identification_id"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span>Contacto Elaboró: </span>
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="cp_template.z_txt_signature_prepared_contact"/>
                                                        </t>
                                                    </t>
                                                    <!-- z_signature_done = True -->
                                                    <t t-if="cp_template.z_signature_done">
                                                        <br/>
                                                        <t t-if="cp_template.z_txt_signature_prepared_contact == '$_name_employee'">
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="cp_template.z_txt_signature_prepared_contact.name"/>
                                                            <br/>
                                                            <span>C.C: </span>
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="o.employee_id.identification_id"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span>Creado Por: </span>
                                                            <span t-if="o.create_uid" t-esc="o.create_uid.name" />
                                                            <br/>
<!--                                                            <span>Hecho Por: </span>-->
<!--                                                            <span t-if="o.write_uid" t-esc="o.write_uid.name" />-->
<!--                                                            <br/>-->
                                                            <span>Sucursal: </span>
                                                            <span t-if="o.write_uid.branch_id" t-esc="o.write_uid.branch_id.name" />
                                                            <br/>
                                                            <span>Cargo: </span>
                                                            <span t-if="cp_template.z_txt_post_prepared" t-esc="cp_template.z_txt_post_prepared"/>
                                                        </t>
                                                        <br/>
                                                    </t>
                                                </td>
                                                <td style="width: 25%" t-if="cp_template.signature_reviewed == True">
                                                    REVISÓ
                                                    <br/>
                                                    <t t-if="cp_template.txt_signature_reviewed == '$_name_employee'">
                                                        <span t-if="cp_template.txt_signature_reviewed"
                                                              t-esc="o.employee_id.name"/>
                                                        <br/>
                                                        C.C
                                                        <span t-if="cp_template.txt_signature_reviewed"
                                                              t-esc="o.employee_id.identification_id"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-if="cp_template.txt_signature_reviewed"
                                                              t-esc="cp_template.txt_signature_reviewed"/>
                                                    </t>
                                                </td>
                                                <td style="width: 25%" t-if="cp_template.signature_approved == True">
                                                    APROBÓ
                                                    <br/>
                                                    <t t-if="cp_template.txt_signature_approved == '$_name_employee'">
                                                        <span t-if="cp_template.txt_signature_approved"
                                                              t-esc="o.employee_id.name"/>
                                                        <br/>
                                                        C.C
                                                        <span t-if="cp_template.txt_signature_approved"
                                                              t-esc="o.employee_id.identification_id"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-if="cp_template.txt_signature_approved"
                                                              t-esc="cp_template.txt_signature_approved"/>
                                                    </t>
                                                </td>
                                                <td style="width: 25%" t-if="cp_template.signature_employee == True">
                                                    EMPLEADO
                                                    <br/>
                                                    <t t-if="cp_template.txt_signature_employee == '$_name_employee'">
                                                        <span t-if="cp_template.txt_signature_employee"
                                                              t-esc="o.employee_id.name"/>
                                                        <br/>
                                                        C.C
                                                        <span t-if="cp_template.txt_signature_employee"
                                                              t-esc="o.employee_id.identification_id"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-if="cp_template.txt_signature_employee"
                                                              t-esc="cp_template.txt_signature_employee"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </table>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </t>
                    <t t-if="cp_template.type_header_footer == 'custom'">
                        <t t-call="web.basic_layout">
                            <!-- Encabezado -->
                            <div class="header">
                                <span t-esc="cp_template.header_custom"/>
                            </div>
                            <!-- Contenido dependiendo la estructura -->
                            <t t-if="cp_template.type_report == 'nomina'">
                                <t t-call="hr_payroll.report_payslip"/>
                            </t>
                            <t t-if="cp_template.type_report == 'vacaciones'">
                                <t t-call="zue_hr_payroll.report_liquidacion_vacaciones_document"/>
                            </t>
                            <t t-if="cp_template.type_report in ('prima','cesantias','intereses_cesantias')">
                                <t t-call="zue_hr_payroll.report_liquidacion_cesantias_prima_document"/>
                            </t>
                            <t t-if="cp_template.type_report == 'contrato'">
                                <t t-call="zue_hr_payroll.report_liquidacion_final_document"/>
                            </t>
                            <!-- Firmas y observaciones -->
                            <div style="font-style: normal; font-size: 12px;">
                                <div class="col-md-6 col-md-offset-9">
                                    <t t-if="cp_template.show_observation == True">
                                        <b>Observaciones:</b>
                                        <br/>
                                        <t t-if="o.observation">
                                            <span t-field="o.observation"/>
                                        </t>
                                    </t>
                                    <t t-if="cp_template.notes">
                                        <br/>
                                        <span t-esc="cp_template.notes"/>
                                    </t>
                                    <t t-if="cp_template.signature_prepared == True or cp_template.signature_reviewed == True or cp_template.signature_approved == True or cp_template.signature_employee == True">
                                        <br/>
                                        <br/>
                                        <br/>
                                        <br/>
                                        <table class="table table-striped">
                                            <tr class="text-center">
                                                <!-- Estado Hecho o Elaboró -->
                                                <td style="width: 25%" t-if="cp_template.z_signature_done or cp_template.signature_prepared">
                                                    <strong>ELABORÓ</strong>
                                                    <!-- signature_prepared = True -->
                                                    <t t-if="cp_template.signature_prepared">
                                                        <br/>
                                                        <t t-if="cp_template.z_txt_signature_prepared_contact == '$_name_employee'">
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="o.employee_id.name"/>
                                                            <br/>
                                                            <span>C.C: </span>
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="o.employee_id.identification_id"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span>Contacto Elaboró: </span>
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="cp_template.z_txt_signature_prepared_contact"/>
                                                        </t>
                                                    </t>
                                                    <!-- z_signature_done = True -->
                                                    <t t-if="cp_template.z_signature_done">
                                                        <br/>
                                                        <t t-if="cp_template.z_txt_signature_prepared_contact == '$_name_employee'">
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="cp_template.z_txt_signature_prepared_contact.name"/>
                                                            <br/>
                                                            <span>C.C: </span>
                                                            <span t-if="cp_template.z_txt_signature_prepared_contact" t-esc="o.employee_id.identification_id"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span>Creado Por: </span>
                                                            <span t-if="o.create_uid" t-esc="o.create_uid.name" />
                                                            <br/>
<!--                                                            <span>Hecho Por: </span>-->
<!--                                                            <span t-if="o.write_uid" t-esc="o.write_uid.name" />-->
<!--                                                            <br/>-->
                                                            <span>Sucursal: </span>
                                                            <span t-if="o.write_uid.branch_id" t-esc="o.write_uid.branch_id.name" />
                                                            <br/>
                                                            <span>Cargo: </span>
                                                            <span t-if="cp_template.z_txt_post_prepared" t-esc="cp_template.z_txt_post_prepared"/>
                                                        </t>
                                                        <br/>
                                                    </t>
                                                </td>
                                                <td style="width: 25%" t-if="cp_template.signature_reviewed == True">
                                                    REVISÓ
                                                    <br/>
                                                    <t t-if="cp_template.txt_signature_reviewed == '$_name_employee'">
                                                        <span t-if="cp_template.txt_signature_reviewed"
                                                              t-esc="o.employee_id.name"/>
                                                        <br/>
                                                        C.C
                                                        <span t-if="cp_template.txt_signature_reviewed"
                                                              t-esc="o.employee_id.identification_id"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-if="cp_template.txt_signature_reviewed"
                                                              t-esc="cp_template.txt_signature_reviewed"/>
                                                    </t>
                                                </td>
                                                <td style="width: 25%" t-if="cp_template.signature_approved == True">
                                                    APROBÓ
                                                    <br/>
                                                    <t t-if="cp_template.txt_signature_approved == '$_name_employee'">
                                                        <span t-if="cp_template.txt_signature_approved"
                                                              t-esc="o.employee_id.name"/>
                                                        <br/>
                                                        C.C
                                                        <span t-if="cp_template.txt_signature_approved"
                                                              t-esc="o.employee_id.identification_id"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-if="cp_template.txt_signature_approved"
                                                              t-esc="cp_template.txt_signature_approved"/>
                                                    </t>
                                                </td>
                                                <td style="width: 25%" t-if="cp_template.signature_employee == True">
                                                    EMPLEADO
                                                    <br/>
                                                    <t t-if="cp_template.txt_signature_employee == '$_name_employee'">
                                                        <span t-if="cp_template.txt_signature_employee"
                                                              t-esc="o.employee_id.name"/>
                                                        <br/>
                                                        C.C
                                                        <span t-if="cp_template.txt_signature_employee"
                                                              t-esc="o.employee_id.identification_id"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-if="cp_template.txt_signature_employee"
                                                              t-esc="cp_template.txt_signature_employee"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </table>
                                    </t>
                                </div>
                            </div>
                            <!-- Pie de pagina -->
                            <div class="footer">
                                <span t-esc="cp_template.footer_custom"/>
                            </div>
                        </t>
                    </t>
                </t>
            </t>
        </template>

        <template id="reports_payslip_header_footer_template_final">
            <t t-foreach="docs" t-as="o">
                <t t-set="inside_foreach_docs" t-value="o"/>
                <t t-call="zue_hr_payroll.reports_payslip_header_footer_template"
                   t-lang="o.employee_id.work_contact_id.lang"/>
            </t>
        </template>

    </data>
</odoo>
