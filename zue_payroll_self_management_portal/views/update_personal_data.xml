<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="update_personal_data" name="Actualizar datos personales">
            <body t-att-style="'background-color:'+str(portal_design.z_background_color)+';color:'+str(portal_design.z_primary_color)+';font-family:'+str(portal_design.z_font)+';'">
                <link rel="stylesheet" href="/zue_payroll_self_management_portal/static/src/css/main.css"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
                      integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
                      crossorigin="anonymous"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
                        integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
                        crossorigin="anonymous"/>
                <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"/>
                <t t-call="web.basic_layout">
                    <script src="https://code.jquery.com/jquery-3.6.0.min.js"/>
                    <t t-if="profile_update">
                        <script>
                            $(function () {
                                Swal.fire({
                                    title: 'Felicitaciones!',
                                    text: 'Tus datos han sido actualizados correctamente.',
                                    showDenyButton: false,
                                    showCancelButton: false,
                                    confirmButtonText: 'Continuar',
                                }).then(function (result) {
                                    if (result.isConfirmed) {
                                        window.parent.location.reload();
                                    }
                                });
                            });
                        </script>
                    </t>
                    <div class="oe_structure" t-att-style="'color:'+str(portal_design.z_primary_color)+';'">
                        <main class="container">
                            <br/>
                            <center>
                                <h1>
                                    <b t-att-style="'color:'+str(portal_design.z_primary_color)+';'">Actualización de Datos</b>
                                </h1>
                            </center>
                            <hr/>
                            <form class="form-update-data"
                                  action="/zue_payroll_self_management_portal/update_personal_data_save"
                                  method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <section class="control-edit">
                                    <div class="row g-3">
                                        <div class="col-md-3">
                                            <div class="form-floating mb-3">
                                                <input type="text" class="form-control" id="phone" name="phone"
                                                       placeholder="Telefono" t-att-value="obj.personal_mobile"/>
                                                <label for="phone">Teléfono</label>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-floating mb-3">
                                                <input type="email" class="form-control" id="email" name="email"
                                                       placeholder="Email" t-att-value="obj.personal_email"/>
                                                <label for="email">Email personal</label>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-floating mb-3">
                                                <input type="text" class="form-control" id="street" name="street"
                                                       placeholder="Dirección"
                                                       t-att-value="obj.work_contact_id.street if obj.work_contact_id else ''"/>
                                                <label for="street">Dirección</label>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="form-floating">
                                                <select class="form-select" id="marital" name="marital">
                                                    <option value="single" t-att-selected="obj.marital == 'single'">Soltero(a)</option>
                                                    <option value="married" t-att-selected="obj.marital == 'married'">Casado(a)</option>
                                                    <option value="cohabitant" t-att-selected="obj.marital == 'cohabitant'">Cohabitante legal</option>
                                                    <option value="widower" t-att-selected="obj.marital == 'widower'">Viudo(a)</option>
                                                    <option value="divorced" t-att-selected="obj.marital == 'divorced'">Divorciado(a)</option>
                                                </select>
                                                <label for="marital">Estado Civil</label>
                                            </div>
                                        </div>
                                    </div>
                                </section>
                                <nav>
                                    <div class="nav nav-tabs" id="nav-tab" role="tablist">
                                        <button class="nav-link active" id="nav-profile-tab" data-bs-toggle="tab"
                                                data-bs-target="#info-public" type="button" role="tab"
                                                aria-controls="info-public" aria-selected="true"
                                                t-att-style="'color:'+str(portal_design.z_secondary_color)+';'">
                                            <strong>Información Pública</strong>
                                        </button>
                                        <button class="nav-link" id="nav-contact-tab" data-bs-toggle="tab"
                                                data-bs-target="#info-private" type="button" role="tab"
                                                aria-controls="info-private" aria-selected="false"
                                                t-att-style="'color:'+str(portal_design.z_secondary_color)+';'">
                                            <strong>Información Privada</strong>
                                        </button>
                                    </div>
                                </nav>
                                <div class="tab-content" id="InfoTabContent">
                                    <div class="tab-pane fade show active" id="info-public" role="tabpanel"
                                         aria-labelledby="nav-profile-tab">
                                        <br/>
                                        <section class="control-edit">
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="mobile_phone"
                                                               name="mobile_phone" t-att-value="obj.mobile_phone"
                                                               placeholder="Movil del trabajo"/>
                                                        <label for="mobile_phone">Movil del trabajo</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="work_phone"
                                                               name="work_phone" t-att-value="obj.work_phone"
                                                               placeholder="Teléfono trabajo"/>
                                                        <label for="work_phone">Teléfono trabajo</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating">
                                                        <select class="form-select" id="licencia_rh" name="licencia_rh">
                                                            <option value="op" t-att-selected="obj.licencia_rh == 'op'">O+</option>
                                                            <option value="ap" t-att-selected="obj.licencia_rh == 'ap'">A+</option>
                                                            <option value="bp" t-att-selected="obj.licencia_rh == 'bp'">B+</option>
                                                            <option value="abp" t-att-selected="obj.licencia_rh == 'abp'">AB+</option>
                                                            <option value="on" t-att-selected="obj.licencia_rh == 'on'">O-</option>
                                                            <option value="an" t-att-selected="obj.licencia_rh == 'an'">A-</option>
                                                            <option value="bn" t-att-selected="obj.licencia_rh == 'bn'">B-</option>
                                                            <option value="abn" t-att-selected="obj.licencia_rh == 'abn'">AB-</option>
                                                        </select>
                                                        <label for="licencia_rh">Tipo de sangre</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <h3 t-att-style="'color:'+str(portal_design.z_primary_color)+';'">Información Licencia</h3>
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="licencia_categoria" name="licencia_categoria">
                                                            <option value="">Seleccione una opcion</option>
                                                            <option value="a1" t-att-selected="obj.licencia_categoria == 'a1'">A1</option>
                                                            <option value="a2" t-att-selected="obj.licencia_categoria == 'a2'">A2</option>
                                                            <option value="b1" t-att-selected="obj.licencia_categoria == 'b1'">B1</option>
                                                            <option value="b2" t-att-selected="obj.licencia_categoria == 'b2'">B2</option>
                                                            <option value="b3" t-att-selected="obj.licencia_categoria == 'b3'">B3</option>
                                                            <option value="c1" t-att-selected="obj.licencia_categoria == 'c1'">C1</option>
                                                            <option value="c2" t-att-selected="obj.licencia_categoria == 'c2'">C2</option>
                                                            <option value="c3" t-att-selected="obj.licencia_categoria == 'c3'">C3</option>
                                                        </select>
                                                        <label for="licencia_categoria">Categoria</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="date" class="form-control" id="licencia_vigencia"
                                                               name="licencia_vigencia" t-att-value="obj.licencia_vigencia"
                                                               placeholder="Vigencia"/>
                                                        <label for="licencia_vigencia">Vigencia</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="licencia_restricciones"
                                                               name="licencia_restricciones"
                                                               t-att-value="obj.licencia_restricciones"
                                                               placeholder="Restricciones"/>
                                                        <label for="licencia_restricciones">Restricciones</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>
                                    </div>
                                    <div class="tab-pane fade" id="info-private" role="tabpanel"
                                         aria-labelledby="nav-contact-tab">
                                        <br/>
                                        <section class="control-edit">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="country_id" name="country_id">
                                                            <t t-foreach="list_countries" t-as="country">
                                                                <option t-att-value="country['id']"
                                                                        t-att-selected="obj.country_id and obj.country_id.id == country['id']">
                                                                    <t t-esc="country['name']"/>
                                                                </option>
                                                            </t>
                                                        </select>
                                                        <label for="country_id">Nacionalidad</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="date" class="form-control" id="date_birthday"
                                                               name="date_birthday" t-att-value="obj.birthday"
                                                               placeholder="Fecha de nacimiento"/>
                                                        <label for="date_birthday">Fecha de nacimiento</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="place_of_birth"
                                                               name="place_of_birth" t-att-value="obj.place_of_birth"
                                                               placeholder="Lugar de nacimiento"/>
                                                        <label for="place_of_birth">Lugar de nacimiento</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="country_of_birth" name="country_of_birth">
                                                            <t t-foreach="list_countries" t-as="country">
                                                                <option t-att-value="country['id']"
                                                                        t-att-selected="obj.country_of_birth and obj.country_of_birth.id == country['id']">
                                                                    <t t-esc="country['name']"/>
                                                                </option>
                                                            </t>
                                                        </select>
                                                        <label for="country_of_birth">País de Nacimiento</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="emergency_contact"
                                                               name="emergency_contact" t-att-value="obj.emergency_contact"
                                                               placeholder="Contacto de emergencia"/>
                                                        <label for="emergency_contact">Contacto de emergencia</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="emergency_phone"
                                                               name="emergency_phone" t-att-value="obj.emergency_phone"
                                                               placeholder="Teléfono de emergencia"/>
                                                        <label for="emergency_phone">Teléfono de emergencia</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="emergency_relationship"
                                                               name="emergency_relationship"
                                                               t-att-value="obj.emergency_relationship"
                                                               placeholder="Parentesco"/>
                                                        <label for="emergency_relationship">Parentesco</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="certificate" name="certificate">
                                                            <option value="">Seleccione una opcion</option>
                                                            <option value="primary" t-att-selected="obj.certificate == 'primary'">Primaria</option>
                                                            <option value="academic_bachelor" t-att-selected="obj.certificate == 'academic_bachelor'">Bachiller</option>
                                                            <option value="technical" t-att-selected="obj.certificate == 'technical'">Técnico</option>
                                                            <option value="technologist" t-att-selected="obj.certificate == 'technologist'">Tecnólogo</option>
                                                            <option value="academic" t-att-selected="obj.certificate == 'academic'">Profesional Universitario</option>
                                                            <option value="specialist" t-att-selected="obj.certificate == 'specialist'">Especialista</option>
                                                            <option value="magister" t-att-selected="obj.certificate == 'magister'">Magister</option>
                                                            <option value="doctor" t-att-selected="obj.certificate == 'doctor'">Doctor</option>
                                                        </select>
                                                        <label for="certificate">Nivel de certificado</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="study_field"
                                                               name="study_field" t-att-value="obj.study_field"
                                                               placeholder="Campo de estudio"/>
                                                        <label for="study_field">Campo de estudio</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="study_school"
                                                               name="study_school" t-att-value="obj.study_school"
                                                               placeholder="Escuela"/>
                                                        <label for="study_school">Escuela</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="z_stratum" name="z_stratum">
                                                            <option value="1" t-att-selected="obj.z_stratum == '1'">1</option>
                                                            <option value="2" t-att-selected="obj.z_stratum == '2'">2</option>
                                                            <option value="3" t-att-selected="obj.z_stratum == '3'">3</option>
                                                            <option value="4" t-att-selected="obj.z_stratum == '4'">4</option>
                                                            <option value="5" t-att-selected="obj.z_stratum == '5'">5</option>
                                                            <option value="6" t-att-selected="obj.z_stratum == '6'">6</option>
                                                        </select>
                                                        <label for="z_stratum">Estrato</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="z_ethnic_group" name="z_ethnic_group">
                                                            <option value="none" t-att-selected="obj.z_ethnic_group == 'none'">Ninguno</option>
                                                            <option value="indigenous" t-att-selected="obj.z_ethnic_group == 'indigenous'">Indígena</option>
                                                            <option value="afrocolombian" t-att-selected="obj.z_ethnic_group == 'afrocolombian'">Afrocolombiano</option>
                                                            <option value="gypsy" t-att-selected="obj.z_ethnic_group == 'gypsy'">Gitano</option>
                                                            <option value="raizal" t-att-selected="obj.z_ethnic_group == 'raizal'">Raizal</option>
                                                        </select>
                                                        <label for="z_ethnic_group">Grupo étnico</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-floating mb-3">
                                                        <select class="form-select" id="z_victim_armed_conflict" name="z_victim_armed_conflict">
                                                            <option value="yes" t-att-selected="obj.z_victim_armed_conflict == 'yes'">Si</option>
                                                            <option value="not" t-att-selected="obj.z_victim_armed_conflict == 'not'">No</option>
                                                        </select>
                                                        <label for="z_victim_armed_conflict">Victima del conflicto armado</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>
                                    </div>
                                </div>
                                <br/>
                                <input type="submit" class="btn btn-outline-success btn-lg w-100"
                                       t-att-style="'border-color:'+str(portal_design.z_secondary_color)+';background-color:'+str(portal_design.z_secondary_color)+';color:'+str(portal_design.z_primary_color)+';'"
                                       value="Actualizar"/>
                            </form>
                            <br/>
                        </main>
                    </div>
                </t>
            </body>
        </template>
    </data>
</odoo>
