<odoo>
    <data>
		<record id="view_zue_electronic_invoice_form_account_move" model="ir.ui.view">
			<field name="name">zue_electronic_invoice.account_move_inherit</field>
			<field name="model">account.move</field>
			<field name="priority">60</field>
			<field name="inherit_id" ref="account.view_move_form"/>
			<field name="arch" type="xml">
                <xpath expr="//button[@name='preview_invoice']" position="replace">
<!--                    <button name="get_xml" type="object" string="FE - Generar Archivo"/>-->
                    <button name="send_all_process" type="object" string="ENVIO FE" invisible="move_type not in ['out_invoice', 'out_refund']"/>
<!--                    <button name="get_xml_v2" type="object" string="FE v2 XML"/>-->
<!--                    <button name="send_xml_FE" type="object" string="Enviar Archivo FE" states="posted"/>-->
<!--                    <button name="check_status_FE" type="object" string="Comprobar Estado FE" states="posted"/>-->
                    <button name="download_pdf_file_FE" type="object" string="Descargar PDF FE" invisible="move_type not in ['out_invoice', 'out_refund']"/>
<!--                    <button name="get_cufe_FE" type="object" string="Obtener CUFE" states="posted"/>-->
                </xpath>
                <xpath expr="//group[@id='header_right_group']" position="after">
                    <group>
                        <field name="z_purchase_order"/>
                        <field name="description_code_credit" invisible="move_type != 'out_refund'"/>
                        <field name="description_code_debit" invisible="move_type != 'in_refund'"/>
                    </group>
                    <group id="FE_ZUE">
                        <field name="cufe_cude_ref" readonly="1" force_save="1"/>
                        <field name="fe_status" readonly="1" force_save="1" invisible="move_type not in ['out_invoice', 'out_refund']"/>
                        <field name="fe_msg_result" invisible="1"/>
                    </group>
                </xpath>

                <xpath expr="//group[@id='header_right_group']" position="after">
                    <group name="fe_zue_fields" invisible="move_type not in ['out_invoice', 'out_refund'] or country_code != 'CO'">
                        <field name="fe_payment_option_id" readonly="state != 'draft'"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='partner_shipping_id']" position="before">
					<field name="x_fe_sent" readonly="1" invisible="move_type in ['in_invoice', 'in_refund']"/>
                    <field name="x_support_document_sent" readonly="move_type in ['in_invoice', 'in_refund']" invisible="move_type in ['out_invoice', 'out_refund']"/>
                </xpath>
                <xpath expr="//button[@name='button_draft']" position="attributes">
                    <attribute name="invisible">fe_status == 'accepted' or x_support_document_sent == True</attribute>
                </xpath>
			</field>
		</record>

<!--        Vista métodos de pago-->
        <record model="ir.actions.act_window" id="fe_payment_options_action">
            <field name="name">Métodos de pago</field>
            <field name="res_model">fe.payment.options</field>
            <field name="view_mode">list,form</field>
		</record>

        <record model="ir.ui.view" id="fe_payment_options_list">
            <field name="name">Lista métodos de pago</field>
            <field name="model">fe.payment.options</field>
            <field name="arch" type="xml">
                <list string="Métodos de pago" editable="bottom">
                    <field name="code"/>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_partner_zue_electronic_invoice_form" model="ir.ui.view">
            <field name="name">res.partner.zue.electronic.invoice.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='website']" position="before">
                    <field name="x_email_fe"/>
                </xpath>
            </field>
        </record>

        <record model="ir.actions.server" id="zue_envio_masivo_fe">
            <field name="name">Envío FE</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="state">code</field>
            <field name="code">
                action = env['account.move'].browse(env.context['active_ids']).masive_send_fe()
            </field>
        </record>

        <record model="ir.actions.server" id="zue_download_masivo_pdf_file_fe">
            <field name="name">Descargar PDF FE</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="binding_model_id" ref="model_account_move"/>
            <field name="state">code</field>
            <field name="code">
                action = env['account.move'].browse(env.context['active_ids']).download_massive_pdf_file_fe()
            </field>
        </record>

        <record id="zue_view_account_move_reversal_form" model="ir.ui.view">
            <field name="name">zue_electronic_invoice.account_move_reversal_inherit</field>
			<field name="model">account.move.reversal</field>
			<field name="priority">60</field>
			<field name="inherit_id" ref="account.view_account_move_reversal"/>
			<field name="arch" type="xml">
                <xpath expr="//field[@name='reason']" position="after">
                    <field name="move_type" invisible="1"/>
                    <field name="description_code_credit" invisible="move_type not in ['out_refund','out_invoice']" required="move_type in ['out_refund','out_invoice']"/>
                    <field name="description_code_debit" invisible="move_type not in ['in_refund','in_invoice']" required="move_type in ['in_refund','in_invoice']"/>
                </xpath>
            </field>
        </record>

<!--        Botón confirmación antes de publicar-->
        <record id="zue_view_move_form_inherit_confirm_post" model="ir.ui.view">
            <field name="name">zue.account.move.form.inherit.confirm.post</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='action_post'][2]" position="replace">
                    <button name="action_post" type="object" string="Post" class="btn-primary" invisible="z_dian_alert_type != 'none'"/>

                    <button name="action_post" type="object" string="Post" class="btn-primary" invisible="z_dian_alert_type != 'date'"
                            confirm="Su resolución de facturación DIAN está próxima a vencer por fecha. ¿Desea continuar?"/>

                    <button name="action_post" type="object" string="Post" class="btn-primary" invisible="z_dian_alert_type != 'folios'"
                            confirm="Su resolución de facturación DIAN está próxima a vencer por folios. ¿Desea continuar?"/>

                    <button name="action_post" type="object" string="Post" class="btn-primary" invisible="z_dian_alert_type != 'both'"
                            confirm="Su resolución de facturación DIAN está próxima a vencer por fecha y por folios. ¿Desea continuar?"/>
                </xpath>

                <xpath expr="//sheet" position="inside">
                    <field name="z_dian_alert_type" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>