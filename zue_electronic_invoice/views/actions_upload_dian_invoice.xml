<odoo>
    <data>
        <!-- Vista del formulario de account.move -->
        <record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit.zip</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="generate_catalog" type="object" string="Generar Catálogo" class="btn-info" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
