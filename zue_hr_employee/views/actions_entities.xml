<odoo>
    <data>
        <!-- TIPOS DE ENTIDADES VIEWS -->
        <record id="zue_menu_action_types_entities" model="ir.actions.act_window">
            <field name="name">Tipos de entidades</field>
            <field name="res_model">hr.contribution.register</field>
            <field name="view_mode">list</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crear Tipo de entidad
                </p>
            </field>
        </record>

        <record model="ir.ui.view" id="zue_hr_employee.list_types_entities">
            <field name="name">zue list types entities</field>
            <field name="model">hr.contribution.register</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="type_entities"/>
                    <field name="note"/>
                </list>
            </field>
        </record>
        <!-- ENTIDADES EMPLEADOS VIEWS -->
        <record id="zue_menu_action_employee_entities" model="ir.actions.act_window">
            <field name="name">Entidades</field>
            <field name="res_model">hr.employee.entities</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crear Entidad
                </p>
            </field>
        </record>

        <record model="ir.ui.view" id="zue_hr_employee.list_employee_entities">
            <field name="name">zue list employee entities</field>
            <field name="model">hr.employee.entities</field>
            <field name="arch" type="xml">
                <list>
                    <field name="partner_id"/>
                </list>
            </field>
        </record>

        <!-- <record model="ir.ui.view" id="zue_hr_employee.search_employee_entities">
            <field name="name">zue search employee entities</field>
            <field name="model">hr.employee.entities</field>
            <field name="arch" type="xml">
                <search string="Entidades">
                  <field name="partner_id"/>                  
                </search>
             </field>
         </record> -->

        <record model="ir.ui.view" id="zue_hr_employee.form_employee_entities">
            <field name="name">zue form employee entities</field>
            <field name="model">hr.employee.entities</field>
            <field name="arch" type="xml">
                <form>
                    <sheet string="Entidades empleados">
                        <group colspan="2">
                            <field name="partner_id" can_create="false" can_write="false" colspan="2"/>
                            <field name="types_entities" colspan="2" can_create="false" can_write="false"
                                   widget='many2many_checkboxes'/>
                        </group>
                        <group>
                            <group>
                                <field name="code_pila_eps"/>
                                <field name="code_pila_ccf"/>
                            </group>
                            <group>
                                <field name="code_pila_regimen"/>
                                <field name="code_pila_exterior"/>
                            </group>
                        </group>
                        <group colspan="2">
                            <field name="order" widget='radio' colspan="2"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>