<odoo>
    <data>

        <record id="ir_seq_hr_version" model="ir.sequence">
            <field name="name">RRHH Contratos Empleados</field>
            <field name="code">hr.version.seq</field>
            <field name="prefix">CTO/</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
            <field name="number_next_actual">1</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Crear record rule para filtrar las sucursales - Contratos -->
        <record id="rule_employee_version_zue_res_branch" model="ir.rule">
            <field name="name">Permisos sucursales contratos empleados</field>
            <field name="model_id" ref="model_hr_version"/>
            <field name="domain_force">
                ['|','|',('employee_id.branch_id','in',user.branch_ids.ids),('employee_id.branch_id','=',False),('employee_id','=',False)]
            </field>
        </record>

        <!-- Botones de nómina en el mismo header que Iniciar plan / Solicitud de firma -->
        <record id="view_zue_hr_employee_form_header_payroll_buttons" model="ir.ui.view">
            <field name="name">hr.employee.form.header.payroll.buttons</field>
            <field name="model">hr.employee</field>
            <field name="priority">18</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/header[1]" position="inside">
                    <button string="Certificado laboral" name="generate_labor_certificate" type="object" groups="hr_payroll.group_hr_payroll_user"/>
                    <button string="Carta de retiro de cesantías" name="generate_report_severance" type="object" groups="hr_payroll.group_hr_payroll_user"/>
                    <button string="Libro de cesantías" name="print_book_cesantias" type="object" groups="hr_payroll.group_hr_payroll_user"/>
                    <button string="Libro de vacaciones" name="print_book_vacaciones" type="object" groups="hr_payroll.group_hr_payroll_user"/>
                </xpath>
            </field>
        </record>

        <!-- Formulario de contratos - ajustes -->
        <record id="view_zue_hr_employee_form_version" model="ir.ui.view">
            <field name="name">hr.version.zue.hr.employee.form.inherit</field>
            <field name="model">hr.employee</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <page name="payroll_information" position="after">
                    <page name="zue_contract" string="CO Nómina" groups="hr_payroll.group_hr_payroll_user">
                        <group>
                            <group>
                                <field name="view_inherit_employee" invisible="1"/>
                                <field name="sequence" force_save="1" readonly="1"/>
                                <field name="contract_type"/>
                                <field name="subcontract_type"/>
                                <field name="modality_salary"/>
                                <field name="method_schedule_pay" widget="radio"/>
                                <field name="code_sena"/>
                                <field name="type_employee" invisible="1"/>
                                <field name="z_state_finished"/>
                                <field name="retirement_date" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="z_previous_start_date"/>
                                <field name="risk_id" required="1"/>
                                <field name="z_economic_activity_level_risk_id"
                                       domain="[('z_risk_class_id','=',risk_id)]"/>
                                <field name="z_employer_replacement_date"/>
                                <field name="not_validate_top_auxtransportation"/>
                                <field name="not_pay_overtime"/>
                                <field name="z_pay_auxtransportation"/>
                                <field name="z_not_pay_auxtransportation"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Cambios de Salario" name="change_wage_tab">
                                <group colspan="2">
                                    <field name="change_wage_ids" nolabel="1">
                                        <list string="Cambios salario básico" editable="top">
                                            <field name="date_start" required="1"/>
                                            <field name="wage" required="1"/>
                                            <field name="job_id"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Devengos &amp; Deducciones" name="dev_and_ded">
                                <group colspan="2">
                                    <field name="concepts_ids" nolabel="1" colspan="2"
                                           context="{'default_type_employee': type_employee}">
                                        <list string="Deducciones o Devengos, conceptos de nómina">
                                            <!-- <field name="type_employee" invisible="1"/> -->
                                            <field name="input_id"/>
                                            <field name="amount"/>
                                            <field name="period"/>
                                            <field name="aplicar"/>
                                            <field name="date_start"/>
                                            <!-- <field name="date_end"/> -->
                                            <field name="partner_id"/>
                                            <field name="state"/>
                                        </list>
                                        <form>
                                            <header>
                                                <button name="change_state_done" type="object"
                                                        invisible="state != 'draft'" string="Aprobar"
                                                        class="oe_highlight"/>
                                                <button name="change_state_cancel" type="object"
                                                        invisible="state != 'done'" string="Cancelar / Finalizar"
                                                        class="oe_highlight"/>
                                                <field name="state" widget="statusbar"/>
                                            </header>
                                            <sheet string="Deducciones o Devengos, conceptos de nómina">
                                                <group>
                                                    <group>
                                                        <field name="type_employee" invisible="1"/>
                                                        <field name="input_id"/>
                                                        <field name="amount"/>
                                                        <field name="period"/>
                                                        <field name="aplicar"/>
                                                    </group>
                                                    <group>
                                                        <field name="date_start"/>
                                                        <field name="date_end"/>
                                                        <field name="attached_name" invisible="1"/>
                                                        <field name="attached" widget="binary"/>
                                                    </group>
                                                    <group string="Entidades">
                                                        <field name="partner_id"/>
                                                        <field name="embargo_judged"/>
                                                        <field name="embargo_process"/>
                                                    </group>
                                                </group>
                                                <group col="4">
                                                    <field name="detail" colspan="4"/>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>
                            </page>
                            <page string="Tributaria" name="tributaria">
                                <group>
                                    <field name="retention_procedure" widget="radio"/>
                                    <field name="fixed_value_retention_procedure"
                                           invisible="retention_procedure != 'fixed'"/>
                                    <field name="deductions_rtf_ids" colspan="2">
                                        <list string="hr.contract.deductions.rtf" editable="bottom">
                                            <field name="input_id"/>
                                            <field name="date_start"/>
                                            <field name="date_end"/>
                                            <field name="number_months"/>
                                            <field name="value_total"/>
                                            <field name="value_monthly"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Modificaciones contractuales" name="modificaciones_contractuales">
                                <group colspan="2">
                                    <field name="contract_modification_history" nolabel="1" colspan="2">
                                        <list editable="bottom">
                                            <field name="date"/>
                                            <field name="description"/>
                                            <field name="attached"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Fuero o Reubicados" name="fuero_o_reubicados">
                                <group>
                                    <group>
                                        <field name="type_of_jurisdiction"/>
                                        <field name="relocated"/>
                                        <field name="date_i"/>
                                        <field name="date_f"/>
                                    </group>
                                    <group>
                                        <field name="previous_positions"/>
                                        <field name="new_positions"/>
                                        <field name="time_with_the_state"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Dotación" name="dotacion">
                                <group colspan="2">
                                    <field name="employee_endowment_ids" nolabel="1" colspan="2">
                                        <list editable="bottom">
                                            <field name="date"/>
                                            <field name="supplies"/>
                                            <!--                                    <field name="quantity"/>-->
                                            <!--                                    <field name="initial_date"/>-->
                                            <!--                                    <field name="final_date"/>-->
                                            <field name="attached"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </page>
                </page>
            </field>
        </record>

        <!-- DEVENGOS & DEDUCCIONES VIEWS -->
        <record id="zue_menu_action_contract_concepts" model="ir.actions.act_window">
            <field name="name">Devengos y Deducciones por Contrato</field>
            <field name="res_model">hr.contract.concepts</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.ui.view" id="zue_hr_employee.list_contract_concepts">
            <field name="name">zue list contract concepts</field>
            <field name="model">hr.contract.concepts</field>
            <field name="arch" type="xml">
                <list>
                    <field name="type_employee" invisible="1"/>
                    <field name="version_id"/>
                    <field name="input_id"/>
                    <field name="amount"/>
                    <field name="period"/>
                    <field name="aplicar"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="zue_hr_employee.form_contract_concepts">
            <field name="name">zue form contract concepts</field>
            <field name="model">hr.contract.concepts</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="change_state_done" type="object" invisible="state != 'draft'" string="Aprobar"
                                class="oe_highlight"/>
                        <button name="change_state_cancel" type="object" invisible="state != 'done'"
                                string="Cancelar / Finalizar" class="oe_highlight"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done" readonly="1"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="type_employee" invisible="1"/>
                                <field name="version_id"/>
                                <field name="input_id"/>
                                <field name="amount"/>
                                <field name="period"/>
                                <field name="aplicar"/>
                            </group>
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="attached_name" invisible="1"/>
                                <field name="attached" widget="binary"/>
                            </group>
                            <group string="Entidades">
                                <field name="partner_id"/>
                                <field name="embargo_judged"/>
                                <field name="embargo_process"/>
                            </group>
                        </group>
                        <group col="4">
                            <field name="detail" colspan="4"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="search_contract_concepts" model="ir.ui.view">
            <field name="name">zue list contract concepts</field>
            <field name="model">hr.contract.concepts</field>
            <field name="arch" type="xml">
                <search>
                    <field name="version_id"/>
                    <field name="input_id"/>
                </search>
            </field>
        </record>

    </data>
</odoo>