<odoo>
    <data>
        <!-- Ocultar la pestaña Ajustes salariales en CO Nómina -->
        <record id="view_zue_hr_employee_salary_attachment" model="ir.ui.view">
            <field name="name">hr.employee.salary.attachment</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='salary_attachment']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>